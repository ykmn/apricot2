# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/
*.egg-info/

# Secrets — никогда не коммитим
.env
.secret.yaml
config/secret.yaml

# SSL-сертификаты и ключи — никогда не коммитим
ssl/*.pem
ssl/*.crt
ssl/*.key
ssl/*.p12
ssl/*.pfx

# Рабочий конфиг — машино-специфичен, в репо только config.demo/
config/
# Персистентные сессии (генерируются автоматически, содержат токены)
config/sessions.yaml

# Автодетектированные параметры аудио (перезаписываются при сканировании)
config/detected_params.yaml

# Логи
logs/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
preview*.png

# Claude Code — machine-specific
.claude/launch.json

# Экспортированные аудиофайлы
export/*
!export/.gitkeep

# Дисковый кэш индексов (machine-specific, regenerated on startup)
cache_audio/*
cache_playlogs/*
!cache_audio/.gitkeep
!cache_playlogs/.gitkeep
